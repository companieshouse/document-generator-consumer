environment = "live"
aws_profile = "live-eu-west-2"

# service configs
use_set_environment_files = true

required_cpus = 512
required_memory = 1024
service_autoscale_scale_in_cooldown = 600

# Enable Parallel Old Kafka Service
create_old_kafka_service = true
document_generator_consumer_old_kafka_version = "1.3.28" 
